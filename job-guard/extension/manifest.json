{
  "manifest_version": 3,
  "name": "Job Guard",
  "description": "Detects fake job offers instantly",
  "version": "1.0",

  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:8000/*"],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Guard"
  }
}
